generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String              @id @default(uuid())
  name           String
  username       String              @unique
  email          String              @unique
  password       String
  birthDate      DateTime
  avatar         String?
  rating         Float               @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  cep            String
  isVerified     Boolean             @default(false)
  age            User_age
  cellphone      String              @unique
  events         Event[]
  eventsAsArtist EventArtist[]
  sessionList    SessionList[]
  tickets        Ticket[]
  localization   user_localization[]
  verification   user_verification[]
}

model user_localization {
  id           String   @id @default(uuid())
  userId       String
  state        String
  city         String
  street       String
  number       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  neighborhood String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model user_verification {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  code      String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id                  String               @id @default(uuid())
  title               String               @unique
  description         String
  endAt               DateTime
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  cep                 String
  userId              String
  banner              String?
  max_person_quantity Int
  date                DateTime
  appropriate_age     Appropriate_age
  artist              String?
  cellphone           String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  artists             EventArtist[]
  ticketType          TicketType[]
  localization        event_localization[]
}

model EventArtist {
  id        String   @id @default(uuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  artist    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model event_localization {
  id           String   @id @default(uuid())
  eventId      String
  state        String
  city         String
  street       String
  number       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  neighborhood String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Ticket {
  id           String        @id @default(uuid())
  userId       String
  createdAt    DateTime      @default(now())
  ticketTypeId String
  status       Status_Ticket @default(PENDING)
  paymentCode  String?       @unique
  ticketType   TicketType    @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TicketType {
  id        String   @id @default(uuid())
  name      String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  eventId   String
  tickets   Ticket[]
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model SessionList {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Appropriate_age {
  ADULT
  EVERYONE
}

enum User_age {
  ADULT
  MINOR
}

enum Status_Ticket {
  CANCELLED
  PENDING
  CONFIRMED
  USED
}
