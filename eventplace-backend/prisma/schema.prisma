generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Appropriate_age {
  ADULT
  EVERYONE
}

model User {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  email     String   @unique
  password  String
  birthDate DateTime
  avatar    String?
  rating    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cep       String

  events       Event[]
  tickets      Ticket[]
  localization user_localization[]
}

model user_localization {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  state        String
  city         String
  street       String
  neighborhood String
  number       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id                  String          @id @default(uuid())
  title               String          @unique
  description         String
  banner              String
  date                DateTime
  appropriate_age     Appropriate_age
  max_person_quantity Int
  endAt               DateTime
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  cep     String
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  ticketType TicketType[]
  
  localization event_localization[]
}

model event_localization {
  id      String @id @default(uuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  state        String
  city         String
  street       String
  neighborhood String
  number       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  ticketTypeId String
}

model TicketType {
  id        String   @id @default(uuid())
  name      String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  tickets Ticket[]

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
}

model BlackList {
  id        String   @id @default(uuid())
  token     String
  createdAt DateTime @default(now())
}
