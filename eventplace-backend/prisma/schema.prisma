generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  email     String   @unique
  password  String
  birthDate DateTime
  avatar    String?
  rating    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // localizations Localization[]
}

